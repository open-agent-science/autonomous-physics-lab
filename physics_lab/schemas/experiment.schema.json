{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "domain",
    "status",
    "hypothesis_id",
    "method",
    "data"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^EXP-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "PLANNED",
        "RUNNING",
        "COMPLETED",
        "FAILED"
      ]
    },
    "hypothesis_id": {
      "type": "string",
      "pattern": "^HYP-[0-9]{4}$"
    },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "simulator"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "simulator": {
          "type": "string",
          "minLength": 1
        },
        "fitter": {
          "type": "string",
          "minLength": 1
        },
        "comparator": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "data": {
      "type": "object"
    },
    "candidate_models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "formula"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^model_[a-z0-9_]+$"
          },
          "formula": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "comparison_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "reference_value"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^target_[a-z0-9_]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "reference_value": {
            "type": "number"
          },
          "reference_uncertainty": {
            "type": "number",
            "minimum": 0
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "domain",
        "status",
        "hypothesis_id",
        "method",
        "data",
        "candidate_models"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^EXP-[0-9]{4}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "PLANNED",
            "RUNNING",
            "COMPLETED",
            "FAILED"
          ]
        },
        "hypothesis_id": {
          "type": "string",
          "pattern": "^HYP-[0-9]{4}$"
        },
        "method": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "simulator",
            "fitter"
          ],
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "simulator": {
              "type": "string",
              "minLength": 1
            },
            "fitter": {
              "type": "string",
              "minLength": 1
            },
            "comparator": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "data": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "amplitude_range_radians",
                "sample_count"
              ],
              "properties": {
                "amplitude_range_radians": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "start",
                    "end"
                  ],
                  "properties": {
                    "start": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "end": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    }
                  }
                },
                "sample_count": {
                  "type": "integer",
                  "minimum": 3
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "time_range_seconds",
                "sample_count",
                "scenarios"
              ],
              "properties": {
                "time_range_seconds": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "start",
                    "end"
                  ],
                  "properties": {
                    "start": {
                      "type": "number",
                      "minimum": 0
                    },
                    "end": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    }
                  }
                },
                "sample_count": {
                  "type": "integer",
                  "minimum": 3
                },
                "scenarios": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "id",
                      "expected_regime",
                      "mass",
                      "damping",
                      "stiffness",
                      "x0",
                      "v0"
                    ],
                    "properties": {
                      "id": {
                        "type": "string",
                        "pattern": "^case_[a-z0-9_]+$"
                      },
                      "expected_regime": {
                        "type": "string",
                        "enum": [
                          "underdamped",
                          "critical",
                          "overdamped"
                        ]
                      },
                      "mass": {
                        "type": "number",
                        "exclusiveMinimum": 0
                      },
                      "damping": {
                        "type": "number",
                        "minimum": 0
                      },
                      "stiffness": {
                        "type": "number",
                        "exclusiveMinimum": 0
                      },
                      "x0": {
                        "type": "number"
                      },
                      "v0": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        "candidate_models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "formula"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^model_[a-z0-9_]+$"
              },
              "formula": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "comparison_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "label",
              "reference_value"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^target_[a-z0-9_]+$"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "reference_value": {
                "type": "number"
              },
              "unit": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "domain",
        "status",
        "hypothesis_id",
        "method",
        "data",
        "comparison_targets"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^EXP-[0-9]{4}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "PLANNED",
            "RUNNING",
            "COMPLETED",
            "FAILED"
          ]
        },
        "hypothesis_id": {
          "type": "string",
          "pattern": "^HYP-[0-9]{4}$"
        },
        "method": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "simulator",
            "comparator"
          ],
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "simulator": {
              "type": "string",
              "minLength": 1
            },
            "fitter": {
              "type": "string",
              "minLength": 1
            },
            "comparator": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dataset_path",
            "dataset_kind"
          ],
          "properties": {
            "dataset_path": {
              "type": "string",
              "minLength": 1
            },
            "dataset_kind": {
              "type": "string",
              "minLength": 1
            },
            "sample_axes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "holdout_particle": {
              "type": "string",
              "minLength": 1
            },
            "input_particles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "candidate_models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "formula"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^model_[a-z0-9_]+$"
              },
              "formula": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "comparison_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "label",
              "reference_value"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^target_[a-z0-9_]+$"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "reference_value": {
                "type": "number"
              },
              "reference_uncertainty": {
                "type": "number",
                "minimum": 0
              },
              "unit": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  ]
}
