{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_id",
    "run_id",
    "experiment_id",
    "title",
    "hypothesis_id",
    "task_id",
    "code_reference",
    "limitations",
    "engine_version",
    "generated_at",
    "command",
    "input_file_hashes",
    "git_commit",
    "train_range",
    "test_range",
    "best_model_id",
    "best_verdict",
    "verification",
    "artifacts",
    "scores"
  ],
  "properties": {
    "result_id": {
      "type": "string",
      "pattern": "^RESULT-[0-9]{4}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{4}$"
    },
    "experiment_id": {
      "type": "string",
      "pattern": "^EXP-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis_id": {
      "type": "string",
      "pattern": "^HYP-[0-9]{4}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{4}$"
    },
    "code_reference": {
      "type": "string",
      "minLength": 1
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "engine_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "git_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "input_file_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config",
        "experiment",
        "hypothesis",
        "task"
      ],
      "properties": {
        "config": {
          "$ref": "#/$defs/fileHash"
        },
        "experiment": {
          "$ref": "#/$defs/fileHash"
        },
        "hypothesis": {
          "$ref": "#/$defs/fileHash"
        },
        "task": {
          "$ref": "#/$defs/fileHash"
        }
      }
    },
    "train_range": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "items": false
    },
    "test_range": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "items": false
    },
    "best_model_id": {
      "type": "string",
      "pattern": "^model_[a-z0-9_]+$"
    },
    "best_verdict": {
      "type": "string",
      "enum": [
        "VALID_IN_RANGE",
        "VALID",
        "PARTIALLY_VALID",
        "INVALID",
        "OVERFITTED",
        "INCONCLUSIVE"
      ]
    },
    "verification": {
      "$ref": "#/$defs/verificationSummary"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report",
        "metrics",
        "claim_update",
        "claim_update_patch",
        "knowledge_update",
        "knowledge_update_patch",
        "review_summary",
        "review_metadata"
      ],
      "properties": {
        "report": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "string",
          "minLength": 1
        },
        "claim_update": {
          "type": "string",
          "minLength": 1
        },
        "claim_update_patch": {
          "type": "string",
          "minLength": 1
        },
        "knowledge_update": {
          "type": "string",
          "minLength": 1
        },
        "knowledge_update_patch": {
          "type": "string",
          "minLength": 1
        },
        "review_summary": {
          "type": "string",
          "minLength": 1
        },
        "review_metadata": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "model_id",
          "formula",
          "coefficients",
          "complexity_score",
          "train_metrics",
          "test_metrics",
          "composite_score",
          "verdict"
        ],
        "properties": {
          "model_id": {
            "type": "string",
            "pattern": "^model_[a-z0-9_]+$"
          },
          "formula": {
            "type": "string",
            "minLength": 1
          },
          "coefficients": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "number"
            }
          },
          "complexity_score": {
            "type": "integer",
            "minimum": 1
          },
          "train_metrics": {
            "$ref": "#/$defs/errorMetrics"
          },
          "test_metrics": {
            "$ref": "#/$defs/errorMetrics"
          },
          "composite_score": {
            "type": "number",
            "minimum": 0
          },
          "verdict": {
            "type": "string",
            "enum": [
              "VALID",
              "PARTIALLY_VALID",
              "INVALID",
              "OVERFITTED",
              "INCONCLUSIVE"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "fileHash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "errorMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mean_relative_error",
        "max_relative_error"
      ],
      "properties": {
        "mean_relative_error": {
          "type": "number",
          "minimum": 0
        },
        "max_relative_error": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "verificationCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "details",
        "metrics"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "PLACEHOLDER"
          ]
        },
        "details": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "string",
              "boolean"
            ]
          }
        }
      }
    },
    "verificationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "checks"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/verificationCheck"
          }
        }
      }
    }
  }
}
