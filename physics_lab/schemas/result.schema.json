{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_id",
    "run_id",
    "experiment_id",
    "title",
    "hypothesis_id",
    "task_id",
    "code_reference",
    "limitations",
    "engine_version",
    "generated_at",
    "command",
    "input_file_hashes",
    "git_commit",
    "best_verdict",
    "verification",
    "artifacts"
  ],
  "properties": {
    "result_id": {
      "type": "string",
      "pattern": "^RESULT-[0-9]{4}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{4}$"
    },
    "experiment_id": {
      "type": "string",
      "pattern": "^EXP-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis_id": {
      "type": "string",
      "pattern": "^HYP-[0-9]{4}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{4}$"
    },
    "code_reference": {
      "type": "string",
      "minLength": 1
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "engine_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "git_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "input_file_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config",
        "experiment",
        "hypothesis",
        "task"
      ],
      "properties": {
        "config": {
          "$ref": "#/$defs/fileHash"
        },
        "fixture": {
          "$ref": "#/$defs/fileHash"
        },
        "experiment": {
          "$ref": "#/$defs/fileHash"
        },
        "hypothesis": {
          "$ref": "#/$defs/fileHash"
        },
        "task": {
          "$ref": "#/$defs/fileHash"
        }
      }
    },
    "train_range": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "items": false
    },
    "test_range": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "items": false
    },
    "best_model_id": {
      "type": "string",
      "pattern": "^model_[a-z0-9_]+$"
    },
    "best_verdict": {
      "type": "string",
      "enum": [
        "VALID_IN_RANGE",
        "VALID",
        "PARTIALLY_VALID",
        "INVALID",
        "OVERFITTED",
        "INCONCLUSIVE"
      ]
    },
    "gauntlet_candidate_set": {
      "type": "string",
      "enum": [
        "current_11",
        "legacy_10"
      ]
    },
    "verification": {
      "$ref": "#/$defs/verificationSummary"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report",
        "metrics",
        "claim_update",
        "claim_update_patch",
        "knowledge_update",
        "knowledge_update_patch",
        "review_summary",
        "review_metadata"
      ],
      "properties": {
        "report": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "string",
          "minLength": 1
        },
        "claim_update": {
          "type": "string",
          "minLength": 1
        },
        "claim_update_patch": {
          "type": "string",
          "minLength": 1
        },
        "knowledge_update": {
          "type": "string",
          "minLength": 1
        },
        "knowledge_update_patch": {
          "type": "string",
          "minLength": 1
        },
        "review_summary": {
          "type": "string",
          "minLength": 1
        },
        "review_metadata": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "model_id",
          "formula",
          "coefficients",
          "complexity_score",
          "train_metrics",
          "test_metrics",
          "composite_score",
          "verdict"
        ],
        "properties": {
          "model_id": {
            "type": "string",
            "pattern": "^model_[a-z0-9_]+$"
          },
          "formula": {
            "type": "string",
            "minLength": 1
          },
          "coefficients": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "number"
            }
          },
          "complexity_score": {
            "type": "integer",
            "minimum": 1
          },
          "train_metrics": {
            "$ref": "#/$defs/errorMetrics"
          },
          "test_metrics": {
            "$ref": "#/$defs/errorMetrics"
          },
          "composite_score": {
            "type": "number",
            "minimum": 0
          },
          "verdict": {
            "type": "string",
            "enum": [
              "VALID",
              "PARTIALLY_VALID",
              "INVALID",
              "OVERFITTED",
              "INCONCLUSIVE"
            ]
          }
        }
      }
    },
    "comparison_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_id",
          "label",
          "reference_value",
          "observed_value",
          "absolute_difference",
          "relative_difference"
        ],
        "properties": {
          "target_id": {
            "type": "string",
            "pattern": "^target_[a-z0-9_]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "reference_value": {
            "type": "number"
          },
          "observed_value": {
            "type": "number"
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "absolute_difference": {
            "type": "number",
            "minimum": 0
          },
          "relative_difference": {
            "type": "number",
            "minimum": 0
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "uncertainty_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "observed_uncertainty": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "reference_uncertainty": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "combined_uncertainty": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "z_score": {
          "type": [
            "number",
            "null"
          ]
        },
        "within_combined_uncertainty": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "review_tier": {
      "type": "string",
      "enum": [
        "AGENT_PUBLISHED",
        "AGENT_VALIDATED",
        "MAINTAINER_REVIEWED",
        "EXTERNAL_REPLICATED"
      ],
      "description": "Multi-tier review level introduced by docs/result-promotion-protocol.md. Optional for backward compatibility; files without this field are treated as LEGACY_UNTIERED for validation only."
    },
    "agent_proposal_evaluation": {
      "type": "object",
      "additionalProperties": true,
      "description": "Required when review_tier is AGENT_PUBLISHED or AGENT_VALIDATED. Records which Gate A or Gate B conditions were checked. See docs/result-promotion-protocol.md.",
      "properties": {
        "review_tier_proposed": {
          "type": "string",
          "enum": [
            "AGENT_PUBLISHED",
            "AGENT_VALIDATED"
          ]
        },
        "best_verdict_proposed": {
          "type": "string"
        },
        "gates_checked": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "evidence_summary": {
          "type": "string",
          "minLength": 1
        },
        "followup_for_maintainer": {
          "type": "string"
        },
        "validation_record": {
          "type": "object",
          "additionalProperties": true,
          "description": "Present when review_tier_proposed is AGENT_VALIDATED. Records the independent replay metadata.",
          "properties": {
            "replayed_by": {
              "type": "object",
              "additionalProperties": true
            },
            "replayed_at_utc": {
              "type": "string",
              "format": "date-time"
            },
            "replay_command": {
              "type": "string"
            },
            "tolerance_used": {
              "type": "number"
            },
            "drift_observed": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "review_tier_proposed",
        "gates_checked",
        "evidence_summary"
      ]
    }
  },
  "oneOf": [
    {
      "required": [
        "train_range",
        "test_range",
        "best_model_id",
        "scores"
      ]
    },
    {
      "required": [
        "comparison_summary",
        "uncertainty_summary"
      ]
    }
  ],
  "$defs": {
    "fileHash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "errorMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mean_relative_error",
        "max_relative_error"
      ],
      "properties": {
        "mean_relative_error": {
          "type": "number",
          "minimum": 0
        },
        "max_relative_error": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "verificationCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "details",
        "metrics"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "PLACEHOLDER"
          ]
        },
        "details": {
          "type": "string",
          "minLength": 1
        },
        "gate_b_scope": {
          "type": "string",
          "enum": [
            "gate_a_packaging"
          ]
        },
        "gate_b_treatment": {
          "type": "string",
          "enum": [
            "publication_packaging_annotation_not_replay_metric"
          ]
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "string",
              "boolean"
            ]
          }
        }
      }
    },
    "verificationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "checks"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/verificationCheck"
          }
        }
      }
    }
  }
}
