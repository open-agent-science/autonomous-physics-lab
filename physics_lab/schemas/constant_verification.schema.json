{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConstantVerification",
  "description": "A result artifact for one physical constant verification micro-task.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "constant_symbol",
    "constant_name",
    "domain",
    "source",
    "derivation",
    "check",
    "verdict",
    "claim_ceiling",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CV-[0-9]{4}$"
    },
    "constant_symbol": {
      "type": "string",
      "minLength": 1
    },
    "constant_name": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edition", "reference_value", "uncertainty", "units"],
      "properties": {
        "edition": {
          "type": "string",
          "minLength": 1,
          "description": "Source edition such as 'CODATA 2018' or 'BIPM 2019'."
        },
        "reference_value": {
          "type": "string",
          "description": "Reference numerical value as a string (preserves precision)."
        },
        "uncertainty": {
          "type": "string",
          "description": "Standard uncertainty as published by the source."
        },
        "units": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbolic_form", "assumptions", "input_constants"],
      "properties": {
        "symbolic_form": {
          "type": "string",
          "minLength": 1,
          "description": "Symbolic expression used to derive the constant."
        },
        "assumptions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "input_constants": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "description": "Names of input constants (e.g. 'e', 'epsilon_0', 'hbar', 'c')."
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code_reference", "computed_value", "relative_error", "tolerance"],
      "properties": {
        "code_reference": {
          "type": "string",
          "minLength": 1,
          "description": "Path to the verification code, e.g. physics_lab/engines/constants_verifier.py:fine_structure_constant"
        },
        "computed_value": {
          "type": "string",
          "description": "Computed value as a string (preserves precision)."
        },
        "relative_error": {
          "type": "string",
          "description": "Relative error vs reference, as a string with scientific notation."
        },
        "tolerance": {
          "type": "string",
          "description": "Tolerance threshold (relative)."
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["VERIFIED", "FAILS_AT_TOLERANCE", "INVALID_DERIVATION", "INCONCLUSIVE"]
    },
    "claim_ceiling": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
