{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "campaign_profile_id",
    "task_id",
    "status",
    "sandbox_only",
    "created_by",
    "proposal_paths",
    "artifacts",
    "preflight",
    "limitations",
    "verdict",
    "promotion_boundary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^AGENT-RUN-[0-9]{4}$"
    },
    "campaign_profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{4}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "PREFLIGHT_FAILED",
        "SANDBOX_READY",
        "SANDBOX_COMPLETE",
        "REVIEW_READY",
        "REJECTED"
      ]
    },
    "sandbox_only": {
      "type": "boolean",
      "const": true
    },
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contributor_id",
        "agent_id"
      ],
      "properties": {
        "contributor_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        }
      }
    },
    "proposal_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis",
        "experiment"
      ],
      "properties": {
        "hypothesis": {
          "type": "string",
          "minLength": 1
        },
        "experiment": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metrics",
        "report",
        "limitations",
        "preflight",
        "review_summary"
      ],
      "properties": {
        "metrics": {
          "type": "string",
          "minLength": 1
        },
        "report": {
          "type": "string",
          "minLength": 1
        },
        "limitations": {
          "type": "string",
          "minLength": 1
        },
        "preflight": {
          "type": "string",
          "minLength": 1
        },
        "review_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "checks"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status",
              "notes"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "PASS",
                  "FAIL",
                  "REVIEW_NEEDED"
                ]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "SANDBOX_PASS",
        "SANDBOX_FAIL",
        "FALSIFIED",
        "INCONCLUSIVE",
        "OVERFITTED",
        "REVIEW_NEEDED"
      ]
    },
    "promotion_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writes_canonical_result",
        "claim_promotion_allowed",
        "required_next_step"
      ],
      "properties": {
        "writes_canonical_result": {
          "type": "boolean",
          "const": false
        },
        "claim_promotion_allowed": {
          "type": "boolean",
          "const": false
        },
        "required_next_step": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
