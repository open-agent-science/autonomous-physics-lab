{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "domain",
    "topic",
    "linked_objects",
    "body"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^KNOW-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "linked_objects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypotheses",
        "experiments",
        "claims",
        "tasks"
      ],
      "properties": {
        "hypotheses": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "pattern": "^HYP-[0-9]{4}$"
          }
        },
        "experiments": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "pattern": "^EXP-[0-9]{4}$"
          }
        },
        "claims": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "pattern": "^CLAIM-[0-9]{4}$"
          }
        },
        "tasks": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "pattern": "^TASK-[0-9]{4}$"
          }
        }
      }
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "review_tier": {
      "type": "string",
      "enum": [
        "AGENT_PUBLISHED",
        "AGENT_VALIDATED",
        "MAINTAINER_REVIEWED",
        "EXTERNAL_REPLICATED"
      ],
      "description": "Multi-tier review level introduced by docs/result-promotion-protocol.md. Optional for backward compatibility. In Phase 1 of the protocol, KNOW-* files are maintainer-only; agent-authored knowledge entries are not permitted."
    },
    "agent_proposal_evaluation": {
      "type": "object",
      "additionalProperties": true,
      "description": "Reserved for Phase 2 of docs/result-promotion-protocol.md. In Phase 1 this block should not be populated because agents may not author KNOW-* files. Present only so the schema accepts a future Phase 2 promotion without a schema change.",
      "properties": {
        "review_tier_proposed": {
          "type": "string",
          "enum": [
            "AGENT_PUBLISHED",
            "AGENT_VALIDATED"
          ]
        },
        "gates_checked": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "evidence_summary": {
          "type": "string",
          "minLength": 1
        },
        "followup_for_maintainer": {
          "type": "string"
        }
      },
      "required": [
        "review_tier_proposed",
        "gates_checked",
        "evidence_summary"
      ]
    }
  }
}
