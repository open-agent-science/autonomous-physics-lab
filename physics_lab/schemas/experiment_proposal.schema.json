{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "campaign_profile_id",
    "proposal_kind",
    "status",
    "claim_ceiling",
    "proposed_by",
    "input_references",
    "question",
    "method",
    "inputs",
    "outputs",
    "validation",
    "overclaim_risk",
    "limitations",
    "verdict",
    "maintainer_decision_requested",
    "promotion_boundary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^EXP-PROPOSAL-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "campaign_profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "proposal_kind": {
      "type": "string",
      "enum": [
        "formula_search",
        "classification",
        "audit",
        "falsification",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "PREFLIGHT_READY",
        "PREFLIGHT_FAILED",
        "REVIEW_READY",
        "REJECTED"
      ]
    },
    "claim_ceiling": {
      "type": "string",
      "minLength": 1
    },
    "proposed_by": {
      "$ref": "#/$defs/proposedBy"
    },
    "input_references": {
      "$ref": "#/$defs/nonemptyStringList"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "code_references",
        "commands",
        "parameters"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "code_references": {
          "$ref": "#/$defs/nonemptyStringList"
        },
        "commands": {
          "$ref": "#/$defs/nonemptyStringList"
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "datasets",
        "constants",
        "prior_results",
        "assumptions"
      ],
      "properties": {
        "datasets": {
          "$ref": "#/$defs/stringList"
        },
        "constants": {
          "$ref": "#/$defs/stringList"
        },
        "prior_results": {
          "$ref": "#/$defs/stringList"
        },
        "assumptions": {
          "$ref": "#/$defs/nonemptyStringList"
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sandbox_output_paths",
        "metrics",
        "plots",
        "notes"
      ],
      "properties": {
        "sandbox_output_paths": {
          "$ref": "#/$defs/nonemptyStringList"
        },
        "metrics": {
          "$ref": "#/$defs/nonemptyStringList"
        },
        "plots": {
          "$ref": "#/$defs/stringList"
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "validation": {
      "$ref": "#/$defs/experimentValidation"
    },
    "overclaim_risk": {
      "$ref": "#/$defs/overclaimRisk"
    },
    "limitations": {
      "$ref": "#/$defs/nonemptyStringList"
    },
    "verdict": {
      "$ref": "#/$defs/sandboxVerdict"
    },
    "maintainer_decision_requested": {
      "type": "string",
      "minLength": 1
    },
    "promotion_boundary": {
      "$ref": "#/$defs/experimentPromotionBoundary"
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonemptyStringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "proposedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contributor_id",
        "agent_id",
        "task_id"
      ],
      "properties": {
        "contributor_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "agent_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^TASK-[0-9]{4}$"
        }
      }
    },
    "experimentValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pass_condition",
        "fail_condition",
        "baseline_or_reference",
        "expected_failure_modes"
      ],
      "properties": {
        "pass_condition": {
          "type": "string",
          "minLength": 1
        },
        "fail_condition": {
          "type": "string",
          "minLength": 1
        },
        "baseline_or_reference": {
          "type": "string",
          "minLength": 1
        },
        "expected_failure_modes": {
          "$ref": "#/$defs/nonemptyStringList"
        }
      }
    },
    "overclaimRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_claim_allowed",
        "forbidden_language",
        "mitigations"
      ],
      "properties": {
        "public_claim_allowed": {
          "type": "boolean",
          "const": false
        },
        "forbidden_language": {
          "$ref": "#/$defs/nonemptyStringList"
        },
        "mitigations": {
          "$ref": "#/$defs/nonemptyStringList"
        }
      }
    },
    "sandboxVerdict": {
      "type": "string",
      "enum": [
        "SANDBOX_PASS",
        "SANDBOX_FAIL",
        "FALSIFIED",
        "INCONCLUSIVE",
        "OVERFITTED",
        "REVIEW_NEEDED"
      ]
    },
    "experimentPromotionBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writes_canonical_result",
        "writes_claim_update",
        "required_next_step"
      ],
      "properties": {
        "writes_canonical_result": {
          "type": "boolean",
          "const": false
        },
        "writes_claim_update": {
          "type": "boolean",
          "const": false
        },
        "required_next_step": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
