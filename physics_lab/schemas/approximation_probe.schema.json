{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Approximation Breakdown Probe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "probe_name",
    "approximation",
    "domain",
    "exact_reference",
    "error_threshold",
    "parameter_range",
    "derivation",
    "check",
    "verdict",
    "claim_ceiling",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^AP-[0-9]{4}$"
    },
    "probe_name": {
      "type": "string",
      "minLength": 1
    },
    "approximation": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "exact_reference": {
      "type": "string",
      "minLength": 1
    },
    "error_threshold": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "parameter_range": {
      "type": "string",
      "minLength": 1
    },
    "derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbolic_form", "assumptions", "parameters"],
      "properties": {
        "symbolic_form": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "parameters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code_reference",
        "breakdown_point",
        "breakdown_units",
        "computed_value",
        "threshold_used"
      ],
      "properties": {
        "code_reference": {
          "type": "string",
          "minLength": 1
        },
        "breakdown_point": {
          "type": "string",
          "minLength": 1
        },
        "breakdown_units": {
          "type": "string",
          "minLength": 1
        },
        "computed_value": {
          "type": "string",
          "minLength": 1
        },
        "threshold_used": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "VERIFIED",
        "FAILS_AT_TOLERANCE",
        "INVALID_DERIVATION",
        "INCONCLUSIVE"
      ]
    },
    "claim_ceiling": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
