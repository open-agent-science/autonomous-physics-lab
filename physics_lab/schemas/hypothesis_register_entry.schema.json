{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HypothesisRegisterEntry",
  "description": "A lightweight hypothesis register entry. Use for PROPOSED ideas before they become full HYP-XXXX hypotheses with experiments.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "domain",
    "mathematical_form",
    "assumptions",
    "falsification_test",
    "claim_ceiling",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^HRE-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "mathematical_form": {
      "type": "string",
      "minLength": 1,
      "description": "Symbolic or algebraic statement of the hypothesis."
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "falsification_test": {
      "type": "string",
      "minLength": 1,
      "description": "A concrete deterministic test that would falsify this hypothesis."
    },
    "claim_ceiling": {
      "type": "string",
      "minLength": 1,
      "description": "The maximum claim that can be made if the hypothesis passes its falsification test."
    },
    "status": {
      "type": "string",
      "enum": ["PROPOSED", "FORMALIZED", "PROMOTED", "REJECTED"]
    },
    "notes": {
      "type": "string"
    },
    "related_objects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
