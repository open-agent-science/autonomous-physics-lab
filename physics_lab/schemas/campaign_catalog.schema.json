{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CampaignCatalog",
  "description": "Lightweight machine-readable campaign portfolio index for parallel agent research lanes. Lives at campaign_profiles/_catalog.yaml and complements missions/current.yaml plus editable campaign_profiles/*.yaml.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "updated",
    "generated_by",
    "source_roots",
    "purpose",
    "relationship_to_missions",
    "campaigns"
  ],
  "properties": {
    "registry_version": {
      "type": "integer",
      "minimum": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "source_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "purpose": {
      "type": "string",
      "minLength": 20
    },
    "relationship_to_missions": {
      "type": "string",
      "minLength": 40
    },
    "campaigns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "domain",
          "surface_type",
          "lifecycle_stage",
          "activity_status",
          "curator",
          "current_stage",
          "agent_capacity",
          "next_validity_gate",
          "best_next_actions",
          "required_gates",
          "allowed_work",
          "forbidden_work",
          "current_results",
          "open_questions",
          "curator_review"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "flagship_validation",
              "active_secondary",
              "source_readiness",
              "pinned_dataset",
              "scaffold",
              "quality_floor",
              "guardrail",
              "watchlist"
            ]
          },
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "surface_type": {
            "type": "string",
            "enum": [
              "formula_audit",
              "fresh_data_benchmark",
              "guardrail_falsification",
              "prediction_reveal",
              "quality_floor",
              "source_pinned_benchmark"
            ]
          },
          "lifecycle_stage": {
            "type": "string",
            "enum": [
              "active_benchmark",
              "mature",
              "monitor_only",
              "pinned_dataset",
              "reveal_blocked",
              "scaffold",
              "source_readiness"
            ]
          },
          "activity_status": {
            "type": "string",
            "enum": [
              "active",
              "active_limited",
              "active_monitor",
              "active_support",
              "planning",
              "watchlist"
            ]
          },
          "curator": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "primary_pool",
              "secondary_pools",
              "review_cadence",
              "transfer_requires"
            ],
            "properties": {
              "primary_pool": {
                "$ref": "#/$defs/curator_pool"
              },
              "secondary_pools": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/curator_pool"
                }
              },
              "review_cadence": {
                "type": "string",
                "enum": [
                  "as_needed",
                  "biweekly",
                  "monthly",
                  "quarterly",
                  "weekly"
                ]
              },
              "transfer_requires": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "current_stage": {
            "type": "string",
            "minLength": 1
          },
          "agent_capacity": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "recommended_parallel_agents",
              "coordination_notes"
            ],
            "properties": {
              "recommended_parallel_agents": {
                "type": "integer",
                "minimum": 0
              },
              "coordination_notes": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "next_validity_gate": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "blocker",
              "target_artifact"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "transfer",
                  "ratification",
                  "external_reveal",
                  "source_readiness"
                ]
              },
              "blocker": {
                "type": "string",
                "minLength": 1
              },
              "target_artifact": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "best_next_actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/action"
            }
          },
          "required_gates": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowed_work": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_work": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "current_results": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "open_questions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "curator_review": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "last_reviewed",
              "review_interval",
              "next_review_due",
              "review_reason",
              "source",
              "notes"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "current",
                  "needs_review",
                  "blocked"
                ]
              },
              "last_reviewed": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "review_interval": {
                "type": "string",
                "enum": [
                  "quarterly_active",
                  "quarterly_blocked",
                  "quarterly_planning",
                  "semiannual_quality_floor"
                ]
              },
              "next_review_due": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "review_reason": {
                "type": "string",
                "enum": [
                  "flagship_validation",
                  "benchmark_monitoring",
                  "source_readiness",
                  "planning_scaffold",
                  "quality_floor_hygiene"
                ]
              },
              "source": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "source_docs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "label"
      ],
      "properties": {
        "task_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^TASK-\\d{4}$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "curator_pool": {
      "type": "string",
      "enum": [
        "frontier_planning",
        "prediction_reveal",
        "result_promotion",
        "source_data_benchmark",
        "verifier_quality_floor"
      ]
    }
  }
}
