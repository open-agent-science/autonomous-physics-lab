{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "type",
    "capabilities",
    "allowed_tasks",
    "constraints",
    "output_formats"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^agent-[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "output_formats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "yaml",
          "json",
          "markdown"
        ]
      }
    }
  }
}
