{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExampleConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_path",
    "hypothesis_path",
    "task_id",
    "run_id",
    "result_id",
    "result_root"
  ],
  "properties": {
    "experiment_path": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis_path": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{4}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{4}$"
    },
    "result_id": {
      "type": "string",
      "pattern": "^RESULT-[0-9]{4}$"
    },
    "result_root": {
      "type": "string",
      "minLength": 1
    },
    "train_fraction": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 1
    },
    "workflow": {
      "type": "string",
      "enum": ["standard", "gauntlet", "reproduction", "dimensional_validation", "neutrino_koide", "quark_koide", "particle_mass_falsifier", "g2_formula_search", "anharmonic_oscillator", "nuclear_mass_baseline", "textbook_exact_reference", "materials_md0002_formation_energy_benchmark", "stellar_ml_debcat_baseline_benchmark", "textbook_firas_wien_peak_consistency"]
    },
    "amplitude_range_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "number"},
        "end": {"type": "number"}
      }
    },
    "include_constrained_candidate": {
      "type": "boolean"
    },
    "include_asymptotic_refined_candidate": {
      "type": "boolean"
    },
    "gauntlet_atom_set": {
      "type": "string",
      "enum": ["current_11", "legacy_10"]
    },
    "knowledge_path": {
      "type": "string",
      "minLength": 1
    },
    "fixture_config_path": {
      "type": "string",
      "minLength": 1
    },
    "challenge_set_path": {
      "type": "string",
      "minLength": 1
    },
    "challenge_set_source_path": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_scope": {
      "type": "string",
      "minLength": 1
    },
    "expected_item_count": {
      "type": "integer",
      "minimum": 1
    },
    "result_title": {
      "type": "string",
      "minLength": 1
    },
    "claim_id": {
      "type": "string",
      "pattern": "^CLAIM-[0-9]{4}$"
    },
    "knowledge_id": {
      "type": "string",
      "pattern": "^KNOW-[0-9]{4}$"
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["workflow"],
        "properties": {
          "workflow": {
            "enum": ["reproduction", "dimensional_validation", "neutrino_koide", "quark_koide", "particle_mass_falsifier", "g2_formula_search", "anharmonic_oscillator", "nuclear_mass_baseline", "textbook_exact_reference", "materials_md0002_formation_energy_benchmark", "stellar_ml_debcat_baseline_benchmark", "textbook_firas_wien_peak_consistency"]
          }
        }
      },
      "then": {},
      "else": {
        "required": ["train_fraction"]
      }
    }
  ]
}
