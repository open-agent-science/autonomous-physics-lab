{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExampleConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_path",
    "hypothesis_path",
    "task_id",
    "run_id",
    "result_id",
    "result_root"
  ],
  "properties": {
    "experiment_path": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis_path": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{4}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^RUN-[0-9]{4}$"
    },
    "result_id": {
      "type": "string",
      "pattern": "^RESULT-[0-9]{4}$"
    },
    "result_root": {
      "type": "string",
      "minLength": 1
    },
    "train_fraction": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 1
    },
    "workflow": {
      "type": "string",
      "enum": ["standard", "gauntlet", "reproduction", "dimensional_validation", "neutrino_koide", "quark_koide"]
    },
    "amplitude_range_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "number"},
        "end": {"type": "number"}
      }
    },
    "include_constrained_candidate": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["workflow"],
        "properties": {
          "workflow": {
            "enum": ["reproduction", "dimensional_validation", "neutrino_koide", "quark_koide"]
          }
        }
      },
      "then": {},
      "else": {
        "required": ["train_fraction"]
      }
    }
  ]
}
