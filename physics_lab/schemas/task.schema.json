{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "type",
    "status",
    "difficulty",
    "priority",
    "input",
    "requirements",
    "accepted_outputs",
    "can_be_done_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "READY",
        "CLAIMED",
        "OPEN",
        "REVIEW_READY",
        "IN_PROGRESS",
        "BLOCKED",
        "DONE",
        "REJECTED"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "strategy_alignment": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis_id",
        "experiment_id"
      ],
      "properties": {
        "hypothesis_id": {
          "type": "string",
          "pattern": "^HYP-[0-9]{4}$"
        },
        "experiment_id": {
          "type": "string",
          "pattern": "^EXP-[0-9]{4}$"
        }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "accepted_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "can_be_done_by": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
