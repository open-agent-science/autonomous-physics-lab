{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "$defs": {
    "scienceExecutionInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis_id",
        "experiment_id"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "science_execution"
          ]
        },
        "hypothesis_id": {
          "type": "string",
          "pattern": "^HYP-[0-9]{4}$"
        },
        "experiment_id": {
          "type": "string",
          "pattern": "^EXP-[0-9]{4}$"
        }
      }
    },
    "planningOnlyInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "related_domain",
        "related_objects",
        "planning_context"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "planning_only"
          ]
        },
        "related_domain": {
          "type": "string",
          "minLength": 1
        },
        "related_objects": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "planning_context": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "related_objects",
        "planning_context"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "workflow"
          ]
        },
        "related_domain": {
          "type": "string",
          "minLength": 1
        },
        "related_objects": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "planning_context": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "type",
    "status",
    "difficulty",
    "priority",
    "input",
    "requirements",
    "accepted_outputs",
    "can_be_done_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "READY",
        "CLAIMED",
        "OPEN",
        "REVIEW_READY",
        "IN_PROGRESS",
        "BLOCKED",
        "DONE",
        "REJECTED",
        "SUPERSEDED"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "closeout": {
      "type": "string",
      "enum": [
        "auto",
        "review"
      ]
    },
    "strategy_alignment": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input": {
      "oneOf": [
        {
          "$ref": "#/$defs/scienceExecutionInput"
        },
        {
          "$ref": "#/$defs/planningOnlyInput"
        },
        {
          "$ref": "#/$defs/workflowInput"
        }
      ]
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "accepted_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "result_artifact_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "reason"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "can_be_done_by": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
