{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "domain",
    "status",
    "hypothesis_id",
    "evidence",
    "scope",
    "body"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CLAIM-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "REFUTED",
        "SUPERSEDED"
      ]
    },
    "hypothesis_id": {
      "type": "string",
      "pattern": "^HYP-[0-9]{4}$"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiments",
        "results"
      ],
      "properties": {
        "experiments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^EXP-[0-9]{4}$"
          }
        },
        "results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^RESULT-[0-9]{4}$"
          }
        }
      }
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "review_tier": {
      "type": "string",
      "enum": [
        "AGENT_PUBLISHED",
        "AGENT_VALIDATED",
        "MAINTAINER_REVIEWED",
        "EXTERNAL_REPLICATED"
      ],
      "description": "Multi-tier review level introduced by docs/result-promotion-protocol.md. Optional for backward compatibility. Files without this field are treated as LEGACY_UNTIERED for validation only. In Phase 1, agent-authored claims must keep status: DRAFT regardless of tier."
    },
    "agent_proposal_evaluation": {
      "type": "object",
      "additionalProperties": true,
      "description": "Required when review_tier is AGENT_PUBLISHED. Records which agent-promotion gates were checked. See docs/result-promotion-protocol.md for the required gate list.",
      "properties": {
        "review_tier_proposed": {
          "type": "string",
          "enum": [
            "AGENT_PUBLISHED",
            "AGENT_VALIDATED"
          ]
        },
        "promotion_target_status": {
          "type": "string",
          "enum": [
            "DRAFT"
          ],
          "description": "Phase 1: agent-authored claims must keep status DRAFT. Maintainer-only DRAFT -> PARTIALLY_SUPPORTED transition."
        },
        "gates_checked": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "evidence_summary": {
          "type": "string",
          "minLength": 1
        },
        "followup_for_maintainer": {
          "type": "string"
        }
      },
      "required": [
        "review_tier_proposed",
        "gates_checked",
        "evidence_summary"
      ]
    }
  }
}
