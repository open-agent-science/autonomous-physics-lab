{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "domain",
    "status",
    "hypothesis_id",
    "evidence",
    "scope",
    "body"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CLAIM-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "REFUTED",
        "SUPERSEDED"
      ]
    },
    "hypothesis_id": {
      "type": "string",
      "pattern": "^HYP-[0-9]{4}$"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiments"
      ],
      "properties": {
        "experiments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^EXP-[0-9]{4}$"
          }
        }
      }
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "minLength": 1
    }
  }
}
