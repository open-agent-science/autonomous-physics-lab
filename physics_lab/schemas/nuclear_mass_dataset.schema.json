{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nuclear Mass Dataset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dataset_id",
    "title",
    "status",
    "description",
    "source_policy",
    "source_dataset",
    "entries"
  ],
  "properties": {
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "curated", "frozen"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source_policy": {
      "type": "string",
      "minLength": 1
    },
    "source_dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "version",
        "citation",
        "url",
        "accessed_on",
        "checksum_sha256",
        "checksum_scope",
        "license_note"
      ],
      "properties": {
        "authority": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "citation": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "accessed_on": { "type": "string", "format": "date" },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "checksum_scope": { "type": "string", "minLength": 1 },
        "license_note": { "type": "string", "minLength": 1 }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "nuclide_id",
          "element",
          "symbol",
          "Z",
          "N",
          "A",
          "evaluation",
          "source_entry",
          "notes"
        ],
        "properties": {
          "nuclide_id": { "type": "string", "minLength": 1 },
          "element": { "type": "string", "minLength": 1 },
          "symbol": { "type": "string", "minLength": 1 },
          "Z": { "type": "integer", "minimum": 0 },
          "N": { "type": "integer", "minimum": 0 },
          "A": { "type": "integer", "minimum": 1 },
          "evaluation": {
            "type": "string",
            "enum": ["measured", "extrapolated", "unspecified"]
          },
          "source_entry": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" },
          "atomic_mass_u": { "type": "number" },
          "atomic_mass_uncertainty_u": {
            "type": "number",
            "minimum": 0
          },
          "mass_excess_keV": { "type": "number" },
          "mass_excess_uncertainty_keV": {
            "type": "number",
            "minimum": 0
          }
        },
        "allOf": [
          {
            "anyOf": [
              {
                "required": ["atomic_mass_u", "atomic_mass_uncertainty_u"]
              },
              {
                "required": ["mass_excess_keV", "mass_excess_uncertainty_keV"]
              }
            ]
          }
        ]
      }
    }
  }
}
