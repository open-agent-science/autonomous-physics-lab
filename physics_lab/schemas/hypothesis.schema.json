{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hypothesis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "domain",
    "status",
    "hypothesis",
    "assumptions",
    "variables",
    "evidence",
    "verdict"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^HYP-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "FORMALIZED",
        "TESTING",
        "VALID_IN_RANGE",
        "PARTIALLY_VALID",
        "FALSIFIED",
        "OVERFITTED",
        "INCONCLUSIVE",
        "INTEGRATED"
      ]
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "formula_candidates"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "formula_candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "variables": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "unit",
          "description"
        ],
        "properties": {
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiments"
      ],
      "properties": {
        "experiments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^EXP-[0-9]{4}$"
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "minLength": 1
    }
  }
}
