# Local APL source-acquisition secrets template.
#
# Copy this file to `.apl-local-secrets.env`, fill only the keys needed for
# maintainer-run acquisition tasks, and keep the filled file local. The filled
# file is ignored by git and must never be committed, pasted into PRs, or logged.
#
# Cross-platform presence check:
#
#   python3 scripts/apl_local_secrets.py status --require MP_API_KEY
#
# Cross-platform one-command run:
#
#   python3 scripts/apl_local_secrets.py run -- python3 <acquisition-script>.py
#
# For separate clones or nonstandard worktree layouts, point agents at this
# file without copying it:
#
#   APL_LOCAL_SECRETS_FILE=/absolute/path/to/.apl-local-secrets.env \
#     python3 scripts/apl_local_secrets.py status --require MP_API_KEY
#
# Optional POSIX shell activation:
#
#   set -a; . ./.apl-local-secrets.env; set +a
#
# Materials Property Residuals / Materials Project snapshots.
MP_API_KEY=

# Future key-gated sources should follow the same pattern:
# PROVIDER_API_KEY=
